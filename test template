<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Test</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600&family=IBM+Plex+Sans:wght@400;500;600&family=IBM+Plex+Mono:wght@400;500;600&display=swap" rel="stylesheet">
<style>

/* ============================================================
   ⚙️  CONFIG LIVES IN THE <script> BLOCK NEAR THE BOTTOM.
   Everything above the "STOP EDITING HERE" line in the script
   is content/config you change per test. Everything below it
   is the engine — you shouldn't need to touch it.
   ============================================================ */

:root{
  --ink:        #1C2E3A;
  --ink-soft:   #435363;
  --paper:      #ECEFEA;
  --paper-line: #D3D9CE;
  --card:       #FFFFFF;
  --accent-calm:  #3C6E52;
  --accent-warn:  #C98A2C;
  --accent-alert: #C4453A;
  --mono: 'IBM Plex Mono', ui-monospace, monospace;
  --sans: 'IBM Plex Sans', system-ui, sans-serif;
  --serif: 'Fraunces', Georgia, serif;
}

*{ box-sizing: border-box; }
html,body{ margin:0; padding:0; }
body{
  background: var(--paper);
  background-image:
    linear-gradient(var(--paper-line) 1px, transparent 1px);
  background-size: 100% 32px;
  font-family: var(--sans);
  color: var(--ink);
  min-height: 100vh;
  display:flex;
  justify-content:center;
  padding: 48px 20px 96px;
}
.sheet{
  width:100%;
  max-width: 680px;
  background: var(--card);
  border: 1px solid var(--paper-line);
  box-shadow: 0 1px 0 var(--paper-line), 0 24px 48px -32px rgba(28,46,58,0.35);
}
.eyebrow{
  font-family: var(--mono);
  font-size: 12px;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--ink-soft);
  padding: 18px 32px 0;
}
header.masthead{
  padding: 6px 32px 24px;
  border-bottom: 1px solid var(--paper-line);
}
header.masthead h1{
  font-family: var(--serif);
  font-weight: 600;
  font-size: 32px;
  line-height: 1.15;
  margin: 4px 0 10px;
}
header.masthead p{
  color: var(--ink-soft);
  font-size: 15px;
  line-height: 1.5;
  margin: 0;
}
.meta-row{
  display:flex;
  gap: 24px;
  flex-wrap: wrap;
  padding: 16px 32px;
  border-bottom: 1px solid var(--paper-line);
  font-family: var(--mono);
  font-size: 12px;
  color: var(--ink-soft);
}
.meta-row b{ color: var(--ink); font-weight: 600; }

/* ---- Timer, the signature element ---- */
.timer-bar{
  position: sticky;
  top: 0;
  z-index: 5;
  background: var(--card);
  border-bottom: 1px solid var(--paper-line);
  padding: 14px 32px;
}
.timer-row{
  display:flex;
  align-items: baseline;
  justify-content: space-between;
}
.timer-label{
  font-family: var(--mono);
  font-size: 11px;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--ink-soft);
}
.timer-clock{
  font-family: var(--serif);
  font-variant-numeric: tabular-nums;
  font-size: 30px;
  font-weight: 600;
  color: var(--ink);
  transition: color 0.4s ease;
}
.timer-clock.warn{ color: var(--accent-warn); }
.timer-clock.alert{ color: var(--accent-alert); animation: pulse 1s infinite; }
@keyframes pulse{ 50%{ opacity: 0.45; } }
.timer-track{
  margin-top: 10px;
  height: 3px;
  background: var(--paper-line);
  overflow: hidden;
}
.timer-fill{
  height: 100%;
  background: var(--accent-calm);
  width: 100%;
  transition: width 1s linear, background 0.4s ease;
}
.timer-fill.warn{ background: var(--accent-warn); }
.timer-fill.alert{ background: var(--accent-alert); }

/* ---- Screens ---- */
.screen{ padding: 32px; }
.screen[hidden]{ display:none; }

.field{ margin-bottom: 22px; }
.field label{
  display:block;
  font-family: var(--mono);
  font-size: 12px;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  color: var(--ink-soft);
  margin-bottom: 8px;
}
.field input[type=text], .field input[type=email], .field textarea{
  width:100%;
  border: 1px solid var(--paper-line);
  background: var(--paper);
  padding: 11px 12px;
  font-family: var(--sans);
  font-size: 15px;
  color: var(--ink);
}
.field textarea{ min-height: 84px; resize: vertical; }
.field input:focus, .field textarea:focus{
  outline: 2px solid var(--ink);
  outline-offset: 1px;
}

button.primary{
  font-family: var(--mono);
  font-size: 13px;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  background: var(--ink);
  color: var(--paper);
  border: none;
  padding: 14px 24px;
  cursor: pointer;
}
button.primary:hover{ background: var(--ink-soft); }
button.primary:disabled{ background: var(--paper-line); color: var(--ink-soft); cursor: not-allowed; }
button.ghost{
  font-family: var(--mono);
  font-size: 12px;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  background: transparent;
  color: var(--ink-soft);
  border: 1px solid var(--paper-line);
  padding: 10px 16px;
  cursor: pointer;
  margin-left: 10px;
}
button.ghost:hover{ border-color: var(--ink-soft); color: var(--ink); }

.notice{
  font-size: 14px;
  line-height: 1.5;
  padding: 14px 16px;
  border-left: 3px solid var(--accent-alert);
  background: #FBEEEC;
  color: #7A2E27;
  margin-bottom: 20px;
}

/* ---- Questions ---- */
.question{
  padding: 24px 0;
  border-bottom: 1px solid var(--paper-line);
}
.question:first-of-type{ padding-top: 0; }
.question:last-of-type{ border-bottom: none; }
.q-number{
  font-family: var(--mono);
  font-size: 12px;
  color: var(--ink-soft);
  letter-spacing: 0.06em;
}
.q-prompt{
  font-family: var(--serif);
  font-size: 19px;
  font-weight: 500;
  line-height: 1.4;
  margin: 6px 0 16px;
}
.q-points{ color: var(--ink-soft); font-weight: 400; font-size: 14px; }
.option{
  display:flex;
  align-items:flex-start;
  gap: 10px;
  padding: 10px 12px;
  border: 1px solid var(--paper-line);
  margin-bottom: 8px;
  cursor: pointer;
  font-size: 15px;
}
.option:hover{ border-color: var(--ink-soft); }
.option input{ margin-top: 3px; }
.option.selected{ border-color: var(--ink); background: var(--paper); }

/* ---- Results ---- */
.score-block{
  text-align:center;
  padding: 28px 0 8px;
}
.score-num{
  font-family: var(--serif);
  font-size: 56px;
  font-weight: 600;
}
.score-label{
  font-family: var(--mono);
  font-size: 12px;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--ink-soft);
}
.review-item{ padding: 16px 0; border-bottom: 1px solid var(--paper-line); }
.review-item .tag{
  font-family: var(--mono);
  font-size: 11px;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  padding: 2px 8px;
  display: inline-block;
  margin-bottom: 8px;
}
.tag.correct{ background: #E7F0EA; color: var(--accent-calm); }
.tag.incorrect{ background: #FBEEEC; color: var(--accent-alert); }
.tag.ungraded{ background: var(--paper); color: var(--ink-soft); }

footer.actions{
  display:flex;
  justify-content: flex-end;
  padding: 20px 32px 28px;
}
</style>
</head>
<body>

<div class="sheet">
  <div class="eyebrow" id="eyebrow">TEST</div>
  <header class="masthead">
    <h1 id="titleDisplay">Test title</h1>
    <p id="introDisplay">Instructions go here.</p>
  </header>
  <div class="meta-row">
    <span>Time limit: <b id="metaTimeLimit">—</b></span>
    <span>Closes: <b id="metaDeadline">—</b></span>
    <span>Questions: <b id="metaQCount">—</b></span>
  </div>

  <!-- SCREEN 1: START -->
  <section class="screen" id="screenStart">
    <div class="field">
      <label for="takerName">Your name</label>
      <input type="text" id="takerName" placeholder="e.g. Jordan Lee">
    </div>
    <p id="closedNotice" class="notice" hidden>This test's deadline has passed. It can no longer be started.</p>
    <button class="primary" id="btnStart">Start test</button>
  </section>

  <!-- SCREEN 2: QUIZ -->
  <section class="screen" id="screenQuiz" hidden>
    <div class="timer-bar">
      <div class="timer-row">
        <span class="timer-label">Time remaining</span>
        <span class="timer-clock" id="timerClock">00:00</span>
      </div>
      <div class="timer-track"><div class="timer-fill" id="timerFill"></div></div>
    </div>
    <div id="questionsMount"></div>
    <footer class="actions">
      <button class="primary" id="btnSubmit">Submit answers</button>
    </footer>
  </section>

  <!-- SCREEN 3: RESULTS -->
  <section class="screen" id="screenResults" hidden>
    <div id="scoreBlock"></div>
    <div id="reviewMount"></div>
    <footer class="actions" style="padding:24px 0 0;">
      <button class="ghost" id="btnDownload">Download results (.json)</button>
    </footer>
  </section>
</div>

<script>
/* ============================================================
   1. TEST CONFIG — edit this block for every new test.
      This is the only section you should need to touch.
   ============================================================ */
const TEST_CONFIG = {

  // A short code to tell tests apart at a glance, e.g. "TEST 014"
  testCode: "TEST 001",

  title: "Sample Knowledge Check",
  intro: "Answer every question before time runs out. Your answers submit automatically when the clock hits zero.",

  // How long the taker gets once they hit "Start test", in minutes.
  timeLimitMinutes: 15,

  // Hard deadline — nobody can START the test after this moment.
  // Format: "YYYY-MM-DDTHH:MM:SS" in the taker's local time.
  deadline: "2026-12-31T23:59:59",

  // Questions: type "mc" (multiple choice, auto-graded) or
  // "short" (free-text, ungraded — shown to you for manual review).
  questions: [
    {
      type: "mc",
      prompt: "Which planet is closest to the sun?",
      points: 1,
      options: ["Venus", "Mercury", "Earth", "Mars"],
      correctIndex: 1
    },
    {
      type: "mc",
      prompt: "What is 12 × 8?",
      points: 1,
      options: ["96", "84", "108", "88"],
      correctIndex: 0
    },
    {
      type: "short",
      prompt: "In two or three sentences, explain why the sky appears blue.",
      points: 2
    }
  ]
};
/* ============================================================
   STOP EDITING HERE — engine below. See notes at the very
   bottom of this file for how retakes/collection are handled.
   ============================================================ */

const els = {
  eyebrow: document.getElementById('eyebrow'),
  title: document.getElementById('titleDisplay'),
  intro: document.getElementById('introDisplay'),
  metaTimeLimit: document.getElementById('metaTimeLimit'),
  metaDeadline: document.getElementById('metaDeadline'),
  metaQCount: document.getElementById('metaQCount'),
  screenStart: document.getElementById('screenStart'),
  screenQuiz: document.getElementById('screenQuiz'),
  screenResults: document.getElementById('screenResults'),
  takerName: document.getElementById('takerName'),
  closedNotice: document.getElementById('closedNotice'),
  btnStart: document.getElementById('btnStart'),
  timerClock: document.getElementById('timerClock'),
  timerFill: document.getElementById('timerFill'),
  questionsMount: document.getElementById('questionsMount'),
  btnSubmit: document.getElementById('btnSubmit'),
  scoreBlock: document.getElementById('scoreBlock'),
  reviewMount: document.getElementById('reviewMount'),
  btnDownload: document.getElementById('btnDownload'),
};

let timerInterval = null;
let deadlineForThisAttempt = null;
let totalSeconds = 0;
let answers = [];
let resultsPayload = null;

function fmtDeadline(iso){
  const d = new Date(iso);
  return d.toLocaleString(undefined, { dateStyle: 'medium', timeStyle: 'short' });
}
function pad(n){ return String(n).padStart(2,'0'); }

function renderStaticInfo(){
  els.eyebrow.textContent = TEST_CONFIG.testCode;
  els.title.textContent = TEST_CONFIG.title;
  els.intro.textContent = TEST_CONFIG.intro;
  els.metaTimeLimit.textContent = TEST_CONFIG.timeLimitMinutes + " min";
  els.metaDeadline.textContent = fmtDeadline(TEST_CONFIG.deadline);
  els.metaQCount.textContent = TEST_CONFIG.questions.length;
  document.title = TEST_CONFIG.title;

  if (new Date() > new Date(TEST_CONFIG.deadline)) {
    els.closedNotice.hidden = false;
    els.btnStart.disabled = true;
  }
}

function buildQuestions(){
  els.questionsMount.innerHTML = "";
  answers = TEST_CONFIG.questions.map(() => null);

  TEST_CONFIG.questions.forEach((q, i) => {
    const wrap = document.createElement('div');
    wrap.className = 'question';

    const num = document.createElement('div');
    num.className = 'q-number';
    num.textContent = 'Q' + pad(i+1);
    wrap.appendChild(num);

    const prompt = document.createElement('div');
    prompt.className = 'q-prompt';
    prompt.innerHTML = q.prompt + ' <span class="q-points">(' + q.points + (q.points===1?' pt':' pts') + ')</span>';
    wrap.appendChild(prompt);

    if (q.type === 'mc') {
      q.options.forEach((opt, oi) => {
        const label = document.createElement('label');
        label.className = 'option';
        label.innerHTML = `<input type="radio" name="q${i}" value="${oi}"> <span>${opt}</span>`;
        label.querySelector('input').addEventListener('change', () => {
          answers[i] = oi;
          wrap.querySelectorAll('.option').forEach(o => o.classList.remove('selected'));
          label.classList.add('selected');
        });
        wrap.appendChild(label);
      });
    } else if (q.type === 'short') {
      const ta = document.createElement('textarea');
      ta.placeholder = 'Type your answer…';
      ta.addEventListener('input', () => { answers[i] = ta.value; });
      wrap.appendChild(ta);
    }

    els.questionsMount.appendChild(wrap);
  });
}

function startTest(){
  const timeLimitMs = TEST_CONFIG.timeLimitMinutes * 60 * 1000;
  const personalDeadline = Date.now() + timeLimitMs;
  const hardDeadline = new Date(TEST_CONFIG.deadline).getTime();
  deadlineForThisAttempt = Math.min(personalDeadline, hardDeadline);
  totalSeconds = Math.max(0, Math.round((deadlineForThisAttempt - Date.now()) / 1000));

  buildQuestions();
  els.screenStart.hidden = true;
  els.screenQuiz.hidden = false;

  const startSeconds = totalSeconds;
  updateClock(totalSeconds, startSeconds);
  timerInterval = setInterval(() => {
    const remaining = Math.max(0, Math.round((deadlineForThisAttempt - Date.now()) / 1000));
    updateClock(remaining, startSeconds);
    if (remaining <= 0) {
      clearInterval(timerInterval);
      submitTest(true);
    }
  }, 1000);
}

function updateClock(remaining, startSeconds){
  const m = Math.floor(remaining / 60);
  const s = remaining % 60;
  els.timerClock.textContent = pad(m) + ':' + pad(s);

  const pct = startSeconds > 0 ? (remaining / startSeconds) * 100 : 0;
  els.timerFill.style.width = pct + '%';

  els.timerClock.classList.remove('warn','alert');
  els.timerFill.classList.remove('warn','alert');
  if (remaining <= 30) {
    els.timerClock.classList.add('alert');
    els.timerFill.classList.add('alert');
  } else if (remaining <= startSeconds * 0.2) {
    els.timerClock.classList.add('warn');
    els.timerFill.classList.add('warn');
  }
}

function gradeAndBuildResults(autoSubmitted){
  let earned = 0, possible = 0, gradedQuestions = 0;
  const review = TEST_CONFIG.questions.map((q, i) => {
    possible += q.points;
    let correct = null;
    if (q.type === 'mc') {
      correct = answers[i] === q.correctIndex;
      if (correct) earned += q.points;
      gradedQuestions++;
    }
    return {
      number: i+1,
      type: q.type,
      prompt: q.prompt,
      points: q.points,
      answerGiven: q.type === 'mc'
        ? (answers[i] === null ? null : q.options[answers[i]])
        : (answers[i] || ""),
      correctAnswer: q.type === 'mc' ? q.options[q.correctIndex] : null,
      correct
    };
  });

  return {
    testCode: TEST_CONFIG.testCode,
    testTitle: TEST_CONFIG.title,
    takerName: els.takerName.value || "(name not entered)",
    submittedAt: new Date().toISOString(),
    autoSubmittedOnTimeout: autoSubmitted,
    score: { earned, possible, gradableQuestionCount: gradedQuestions },
    answers: review
  };
}

function renderResults(payload){
  els.screenQuiz.hidden = true;
  els.screenResults.hidden = false;

  const hasGraded = payload.score.gradableQuestionCount > 0;
  els.scoreBlock.innerHTML = hasGraded
    ? `<div class="score-block">
         <div class="score-num">${payload.score.earned} / ${payload.score.possible}</div>
         <div class="score-label">Auto-graded score${payload.autoSubmittedOnTimeout ? ' · time expired' : ''}</div>
       </div>`
    : `<div class="score-block">
         <div class="score-num">Submitted</div>
         <div class="score-label">This test has free-text answers to review manually</div>
       </div>`;

  els.reviewMount.innerHTML = "";
  payload.answers.forEach(a => {
    const item = document.createElement('div');
    item.className = 'review-item';
    let tag = '<span class="tag ungraded">Q' + pad(a.number) + ' · to review</span>';
    if (a.type === 'mc') {
      tag = a.correct
        ? '<span class="tag correct">Q' + pad(a.number) + ' · correct</span>'
        : '<span class="tag incorrect">Q' + pad(a.number) + ' · incorrect</span>';
    }
    item.innerHTML = `
      ${tag}
      <div class="q-prompt" style="font-size:16px;">${a.prompt}</div>
      <div style="font-size:14px;color:var(--ink-soft);">
        Answer given: ${a.answerGiven ? a.answerGiven : '<em>no answer</em>'}
        ${a.correctAnswer ? '<br>Correct answer: ' + a.correctAnswer : ''}
      </div>`;
    els.reviewMount.appendChild(item);
  });
}

function submitTest(autoSubmitted){
  if (timerInterval) clearInterval(timerInterval);
  resultsPayload = gradeAndBuildResults(!!autoSubmitted);
  renderResults(resultsPayload);
}

els.btnStart.addEventListener('click', startTest);
els.btnSubmit.addEventListener('click', () => submitTest(false));

els.btnDownload.addEventListener('click', () => {
  const blob = new Blob([JSON.stringify(resultsPayload, null, 2)], { type: 'application/json' });
  const url = URL.createObjectURL(blob);
  const a = document.createElement('a');
  const safeName = (resultsPayload.takerName || 'results').replace(/[^a-z0-9]+/gi, '_');
  a.href = url;
  a.download = `${TEST_CONFIG.testCode.replace(/\s+/g,'_')}_${safeName}.json`;
  a.click();
  URL.revokeObjectURL(url);
});

renderStaticInfo();

/* ============================================================
   NOTES FOR YOU (not shown to test-takers):

   • DUPLICATING FOR A NEW TEST
     Copy this file, rename it (e.g. test-002-history.html),
     open the copy, and edit only the TEST_CONFIG block above.
     Nothing else needs to change.

   • COLLECTING RESULTS
     There's no server here, so results aren't sent anywhere
     automatically. After submitting, the taker sees their score
     and can click "Download results" to save a .json file they
     send back to you (email, WhatsApp, whatever). If you want
     results to land somewhere automatically across 100+ tests,
     the cleanest free option is pointing this at a Google Form
     as a silent backend — happy to wire that up if useful.

   • PREVENTING RETAKES
     This template doesn't block a second attempt on the same
     device — there's no account system to enforce it. For a
     trusted friend that's rarely an issue. If you need it
     enforced, that also needs the Google Form (or similar)
     backend so you can check "has this person already
     submitted?" before letting them start.

   • HOSTING
     Works opening the file directly, or hosted for free on
     GitHub Pages, Netlify, Vercel, or Google Sites — anywhere
     that serves a static HTML file.
   ============================================================ */
</script>
</body>
</html>
